node_modules/
*.pyc
__pycache__/
.DS_Store
Thumbs.db

# Scientist vault — track knowledge notes, ignore artifacts
.scientist/papers/
.scientist/repos/
.scientist/logs/
.scientist/scripts/
.scientist/vault/assets/*.png
.scientist/vault/assets/*.jpg
.scientist/vault/assets/*.svg
.scientist/vault/.obsidian/
.playwright-mcp/

# MCP server dependencies (installed by user, not committed)
mcp/playwright/node_modules/
mcp/jupyter/node_modules/
mcp/jupyter/.venv/

# Keep the MCP repos but ignore their build artifacts
mcp/*/dist/
mcp/*/build/
mcp/*/.git/
